		<SequenceRef name="ITEM_PRICE_INQUIRY" />
		<SequenceRef name="SCAN_ITEM" values="!{itemid}" iterations="1" />
        <SequenceRef name="SELECT_ADD_ITEM" />
		<SequenceRef name="CHECK_ITEM_IN_THE_TRANSACTION" values="!{itemid}"/>
		<SequenceRef name="SELECT_REFUND" />
		<SequenceRef name="REFUND_TENDER_BY_CASH" values="@getTransaction.getTotal.abs"/>
		<SequenceRef name="PRINT_ONLY" />
		<SequenceRef name="CHANGE_DUE" />
    </TestCase>
