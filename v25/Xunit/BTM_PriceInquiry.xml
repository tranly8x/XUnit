<?xml version="1.0" encoding="ISO-8859-1" standalone="no"?>
<XunitConfig>
	<!-- TEST CASES -->
	<!--PRICE-INQ-SALE-001: Verify that the item id, description and price are displayed correctly when scanning or entering a merchandise item.-->	
    <TestCase name="PRICE-INQ-SALE-001" applicationKey="REGISTER" >
		<Parameter name="itemid" value="%?REGULAR_ITEMS_FILE.ItemId" />
		<SequenceRef name="START_SALE_BEFORE_LOGIN" values="!{userid}, !{password}" />
		<SequenceRef name="SELECT_FIRST_COMM_ASSOC" />
		<SequenceRef name="SKIP_CUST" />		
		<SequenceRef name="ITEM_PRICE_INQUIRY" />
		<SequenceRef name="SCAN_ITEM" values="!{itemid}"/>
		<SequenceRef name="SELECT_ADD_ITEM" />
		<SequenceRef name="CHECK_ITEM_IN_THE_TRANSACTION" values="!{itemid}"/>		
		<SequenceRef name="SELECT_AMT_DUE" />
		<SequenceRef name="TENDER_BY_CASH" values="@getTransaction.getTotal.abs"/>
		<SequenceRef name="PRINT_ONLY" />
		<SequenceRef name="CHANGE_DUE" />
    </TestCase>
	
