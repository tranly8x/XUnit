	 <!--EXCHANGE TRANSACTION-->
	 <!--PRICE-INQ-EXCH-001: Verify that the item id, description and price are displayed correctly when scanning or entering a merchandise item.-->	
 	 <TestCase name="PRICE-INQ-EXCH-001" applicationKey="REGISTER" >
		<Parameter name="custID" value="%?CUSTOMERS_DB.CustId" />
		<Parameter name="itemid" value="%?REGULAR_ITEMS_FILE.ItemId" />
		<SequenceRef name="LOGIN" values="!{userid}, !{password}" />
		<SequenceRef name="START_SALE_LOGGED_IN" />
		<SequenceRef name="SELECT_FIRST_COMM_ASSOC" />
