	<!-- TEST CASES -->
	<TestCase name="NMERCH-WAR-001"	applicationKey="REGISTER"><!-- that user can add warranty into item in current sale transaction	"Pre-Conditions:
		- Warranty loaded into DB

		Steps to verify:
		1. Login into Xstore
		2. Start sale transaction
		3. Add item
		4. Select Non-Merchandise Options
		5. Select Warranty > Add Warranty
		6. Select Current Transaction
		7. Add warranty item
		8. Select the warranty plan
		9. Complete the transaction"
		-->
		<Parameter name="witemId" value="%?WARRANTY_ITEMS_FILE.ItemId" />
		<SequenceRef name="START_SALE_BEFORE_LOGIN" values="!{userid}, !{password}" />
		<SequenceRef name="SELECT_FIRST_COMM_ASSOC" />
		<SequenceRef name="SKIP_CUST" />
		<SequenceRef name="SCAN_WARRANTY_ITEM" values="!{witemId}"/>
		<SequenceRef name="CUSTOMER_SEARCH_BY_ID" values="!{custID}"/>
		<SequenceRef name="SKIP_CUSTOMER_NOTIFICATION" />
		<SequenceRef name="SELECT_BTN_YES" />
		<SequenceRef name="SELECT_AMT_DUE" />
		<SequenceRef name="TENDER_BY_CASH" values="@getTransaction.getTotal.abs"/>
		<SequenceRef name="PRINT_ONLY" />			
	</TestCase>
	<TestCase name="NMERCH-WAR-005"	applicationKey="REGISTER"><!-- that user can add warranty into item in current Blind Return transaction	"Pre-Conditions:
		- Warranty loaded into DB

		Steps to verify:
		1. Login into Xstore
		2. Start blind return transaction
		3. Add item
		4. Select Non-Merchandise Options
		5. Select Warranty > Add Warranty
		6. Select Current Transaction
		7. Add warranty item
		8. Select the warranty plan
		9. Complete the transaction"
		-->
		<Parameter name="witemId" value="%?WARRANTY_ITEMS_FILE.ItemId" />
		<SequenceRef name="START_SALE_BEFORE_LOGIN" values="!{userid}, !{password}" />
		<SequenceRef name="SELECT_FIRST_COMM_ASSOC" />
		<SequenceRef name="CUSTOMER_SEARCH_BY_ID" values="!{custID}"/>
		<SequenceRef name="SKIP_CUSTOMER_NOTIFICATION" />
		<SequenceRef name="SELECT_RETURN_ITEM" />
		<SequenceRef name="SELECT_BTN_NO" />
		<SequenceRef name="SCAN_RETURN_ITEM" values="!{witemId},%?RETURN_REASONS.ReasonCode,%?RETURN_REASONS.CommentReq,0" />		
		<SequenceRef name="SELECT_BTN_YES" />
		<SequenceRef name="SELECT_WARRANTY_PLAN" values="%+WARRANTY_DB.Number"/>
		<SequenceRef name="GO_SALE_SCREEN" />
		<SequenceRef name="SELECT_REFUND" />
		<SequenceRef name="REFUND_TENDER_BY_CASH" values="@getTransaction.getTotal.abs"/>
		<SequenceRef name="PRINT_ONLY" />
		<SequenceRef name="CHANGE_DUE" />
	</TestCase>
		
