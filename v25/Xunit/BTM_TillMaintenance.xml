<XunitConfig>
	<!-- TEST CASES -->
	<!--Till Maintenance TILLMAIN-CASHPICK-001 -enter pickup AMT < System Cash AMT-->	
    <TestCase name="TILLMAIN-CASHPICK-001" applicationKey="REGISTER" >
		<Parameter name="pickupCashAMT" value="20" /> <!--Enter CashAMT need to backup-->
		<SequenceRef name="LOGIN" values="!{userid}, !{password}" />
		<SequenceRef name="SELECT_CASH_PICKUP" />
		<SequenceRef name="ENTER_CASH_AMT" values="!{pickupCashAMT}" />	
		<SequenceRef name="SELECT_DONE" />		
    </TestCase>
	<!--Till Maintenance TILLMAIN-CASHPICK-001 -enter pickup AMT > System Cash AMT-->	
	<TestCase name="TILLMAIN-CASHPICK-002" applicationKey="REGISTER" >
		<SequenceRef name="LOGIN" values="!{userid}, !{password}" />
		<SequenceRef name="SELECT_CASH_PICKUP" />
		<SequenceRef name="ENTER_CASH_AMT" values="@getSessionTenderAmount(USD_CURRENCY).multiply(100).intValue()" />
		<SequenceRef name="SELECT_DONE" />
		<Assertion promptKey="VALIDATION_ERROR_MESSAGE" />
    </TestCase>
	<!--Till Maintenance TILLMAIN-CASHPICK-001 -enter transfer AMT < System Cash AMT-->
	<TestCase name="TILLMAIN-CASHTSF-001" applicationKey="REGISTER" >
		<Parameter name="transferAmount" value="1" />
		<SequenceRef name="LOGIN" values="!{userid}, !{password}" />
		<SequenceRef name="SELECT_CASH_TRANSFER" />
		<SequenceRef name="ENTER_CASH_AMT"  values="!{transferAmount}"/>
		<SequenceRef name="SELECT_DONE" />
    </TestCase>
	<!--Till Maintenance TILLMAIN-CASHPICK-001 -enter transfer AMT > System Cash AMT-->
	<TestCase name="TILLMAIN-CASHTSF-002" applicationKey="REGISTER" >	
		<SequenceRef name="LOGIN" values="!{userid}, !{password}" />
		<SequenceRef name="SELECT_CASH_TRANSFER" />
