		<SequenceRef name="SELECT_DONE" />
    </TestCase>
	<!--Till Maintenance Deposit OverShot=$0 -->
	<TestCase name="TILLMAIN-MIDDEPOSIT-007" applicationKey="REGISTER" >
		<SequenceRef name="LOGIN" values="!{userid}, !{password}" />
		<SequenceRef name="MIDDAY_DEPOSIT_STEPS" />
		<SequenceRef name="SELECT_DONE" /><!--Select Count Complete-->
	</TestCase>
	<!--Till Maintenance Deposit OverShot>$0 -->
	<TestCase name="TILLMAIN-MIDDEPOSIT-008" applicationKey="REGISTER" >
		<Parameter name="depositAmount" value="20" /> <!--Enter deposit amount-->	
		<SequenceRef name="LOGIN" values="!{userid}, !{password}" />
		<SequenceRef name="MIDDAY_DEPOSIT_GREATER" values="!{depositAmount}"/>
		<SequenceRef name="SELECT_DONE" /><!--Select Count Complete-->
		<Assertion promptKey="MIDDAY_DEPOSIT_CASH_AMOUNT_INVALID" />
	</TestCase>
	<!--Till Maintenance Audit OverShot=$0 -->
	<TestCase name="TILLMAIN-TILLAUDIT-007" applicationKey="REGISTER" >
