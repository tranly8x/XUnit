<?xml version="1.0" encoding="ISO-8859-1" standalone="no"?>
<XunitConfig>
	<TestSequence name="INVENTORY_RECEIVING">
		<TestStep action="RECEIVING" description="RECEIVING (PromptOp)"/>
	</TestSequence>
	<!--Setup new layaway-->
	<TestSequence name="LAYAWAY_SETUP" >
		<TestStep action="PRE_LAYAWAY_CHAIN" description="Select Layaway"  />
		<TestStep action="NEW" description="NEW (LayawayRegisterSearchOp)"/>
	</TestSequence>
	<!-- Setup new Special Order -->
	<TestSequence name="SO_SHIP_STORE_SETUP" >
		<SequenceRef name="SPECIAL_ORDER_TRANS" />
        <TestStep action="NEW" description="NEW (SpecOrderRegisterSearchOp)"/>
        <TestStep action="SHIP_STORE" description="SHIP_STORE (PromptShippingDestOp)"/>
	</TestSequence>
	<!--Select Item Lookup before login to Xstore -->
	<TestSequence name="DASHBOARD">
		<Assertion promptKey="HOME_SCREEN_LOGGED_IN" />
        <TestStep action="SHOW_DASHBOARD" description="Dashboard [SHOW_DASHBOARD]"/>
	</TestSequence>
	<!--Select Item Lookup before login to Xstore -->
	<TestSequence name="ITEM_LOOKUP_BEFORE_LOGIN">
		<Assertion promptKey="PROMPT_TO_LOGIN" />
        <TestStep action="GENERIC_ITEM_LOOKUP" description="GENERIC_ITEM_LOOKUP (PromptOp)"/>
	</TestSequence>
	<!--Select Transaction Tax Amount-->
	<TestSequence name="SELECT_TRANSACTION_TAX_AMT">
		<TestStep description="Select transaction tax amount" action="TAX_TRAN_CHANGE_AMOUNT" />
	</TestSequence>
	<!--Select Transaction Tax Percent-->
	<TestSequence name="SELECT_TRANSACTION_TAX_PER">
		<TestStep description="Select transaction tax amount" action="TAX_TRAN_CHANGE_PERCENT" />
	</TestSequence>
	<!--Select View Customer in Sale Transaction-->
	<TestSequence name="SELECT_CUSTOMER_IN_SALE">
		<TestStep description="Select view customer in sale" action="CUSTOMER_SALE_OVERVIEW" />
	</TestSequence>
	<!--Select Transaction Tax Exempt-->
	<TestSequence name="SELECT_TRANSACTION_TAX_EXEMPT">
		<TestStep description="Select transaction tax exempt" action="TAX_TRAN_EXEMPT" />
	</TestSequence>
	<!--Select Login at Home Screen-->
	<TestSequence name="LOGIN" parameters="userid, password">
		<SequenceRef name="ACT_ACCEPT" />
		<TestStep action="ACCEPT" description="ACCEPT (PromptIdPasswordFormOp)">
            <Form name="UID_PASSWORD">
                <Field name="employeeId" value="!{userid}"/>
                <Field name="password" value="!{password}"/>
                <Field name="icon" value="classpath:graphics/Key_Password.gif"/>
                <Field name="privilegeDescription" value="Start Sale"/>
            </Form>
        </TestStep>
	</TestSequence>
	<!--Select Logout at Home Screen-->
	<TestSequence name="LOGOUT" >
		<Assertion promptKey="HOME_SCREEN_LOGGED_IN" />
		<TestStep action="CANCEL" description="CANCEL (PromptOp)"/>
	</TestSequence>
	<!--Select Start Sale at Home Screen-->
	<TestSequence name="START_SALE_BEFORE_LOGIN" parameters="userid, password">
		<TestStep action="MOBILE_START_SALE_LOGIN" description="MOBILE_START_SALE_LOGIN (PromptOp)"/>
		<TestStep action="ACCEPT" description="ACCEPT (PromptIdPasswordFormOp)">
            <Form name="UID_PASSWORD">
                <Field name="employeeId" value="!{userid}"/>
                <Field name="password" value="!{password}"/>
                <Field name="icon" value="classpath:graphics/Key_Password.gif"/>
                <Field name="privilegeDescription" value="Start Sale"/>
            </Form>
        </TestStep>
	</TestSequence>	
	<!--Select Till > Open/Close Option > Store Open at BO-->	
	<TestSequence name="STORE_OPEN_MN">
		<TestStep description="Open Store" action="RETAIL_LOCATION_OPEN" />
		<TestStep description="Verify Open Store" action="YES" />
	</TestSequence>
	<!--Select Till > Open/Close Option > Store Close at BO-->	
	<TestSequence name="STORE_CLOSE_MN">
		<TestStep description="Close Store" action="RETAIL_LOCATION_CLOSE" />
		<TestStep description="Confirm close store" action="YES" />
	</TestSequence>
	<!--Select Till > Open/Close Option > Register Open at BO-->	
	<TestSequence name="REGISTER_OPEN_MN">
		<TestStep description="Open Register" action="WORKSTATION_OPEN" />
		<TestStep description="Verify Open Register" action="YES" />
	</TestSequence>
	<!--Select Till > Open/Close Option > Register Close at BO-->	
	<TestSequence name="REGISTER_CLOSE_MN">
		<TestStep description="Close Register" action="WORKSTATION_CLOSE" />
		<TestStep description="Confirm close register" action="YES" />
	</TestSequence>
	<!--Select Till > Open/Close Option > FORCE Close at BO-->	
	<TestSequence name="FORCE_CLOSE_MN">
		<TestStep description="Select Force Close" action="FORCE_CLOSE_WORKSTATION" />
		<TestStep action="ACCEPT" description="ACCEPT (PromptForceCloseWorkstationOp)" condition="@promptEquals(WORKSTATIONS_STATUS_LIST)">
      <ListSelect index="1"/>
    </TestStep>
    <TestStep action="ACCEPT" description="ACCEPT (PromptOp) (SendIpcCloseRemoteWorkstationMessageOp)" condition="@promptEquals(ERROR_SENDING_IPC)"/>
    <TestStep action="ACCEPT" description="ACCEPT (PromptOp)" condition="@promptEquals(NO_LIST_OPEN_WORKSTATIONS)"/>
	</TestSequence>
	
<!--Menu Option -->
	<!--Select Item Lookup -->
	<TestSequence name="ITEM_LOOKUP">
		<TestStep description="Select Item Lookup " action="GENERIC_ITEM_LOOKUP" />
	</TestSequence>
	<!--Select Customer -->
	<TestSequence name="CUSTOMER" parameters="userid, password">
		<TestStep description="Select Customer " action="CUSTOMER_CENTRIC_SALE" />
		<TestStep action="ACCEPT" description="ACCEPT (PromptIdPasswordFormOp)">
      <Form name="UID_PASSWORD">
        <Field name="employeeId" value="!{userid}"/>
        <Field name="password" value="!{password}"/>
      </Form>
		</TestStep>
	</TestSequence>
	<!--Select Engagement Activity -->
	<TestSequence name="ENGAGEMENT" parameters="userid, password">
		<TestStep description="Select Engagement Activity " action="ENGAGEMENT_ACTIVITY_" />
		<TestStep action="ACCEPT" description="ACCEPT (PromptIdPasswordFormOp)">
      <Form name="UID_PASSWORD">
        <Field name="employeeId" value="!{userid}"/>
        <Field name="password" value="!{password}"/>
        <Field name="icon" value="classpath:graphics/Key_Password.gif"/>
        <Field name="privilegeDescription" value="Start Sale"/>
      </Form>
		</TestStep>
	</TestSequence>
	<!--Select Gift Card Balance -->
	<TestSequence name="GIFT_CARD_BALANCE">
		<TestStep description="Select Gift Card Balance " action="XPAY_BALANCE_INQUIRY" />
	</TestSequence>
	<!--Select Gift Certificate Balance -->
	<TestSequence name="GIFT_CERTIFICATE_BALANCE">
