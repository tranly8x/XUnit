	<TestSequence name="GIFT_RECEIPT_INQUIRY">
		<TestStep description="Select Gift Receipt Inquiry " action="GIFT_RECEIPT_PRICE_LOOKUP" />
	</TestSequence>
	<!--Select Store Credit Balance -->
	<TestSequence name="STORE_CREDIT_BALANCE">
		<TestStep description="Select Store Credit Balance " action="VOUCHER_CREDIT_BALANCE_INQUIRY" />
	</TestSequence>
	<!--Select Flash Sale -->
	<TestSequence name="FLASH_SALE">
		<TestStep description="Select Flash Sale " action="FLASH_SALES_REPORT_VER2" />
	</TestSequence>
	<!--Select Rebate Receipt -->
	<TestSequence name="REBATE_RECEIPT">
		<TestStep description="Select Rebate Receipt " action="PRINT_REBATE_RECEIPT" />
	</TestSequence>
	<!--Select Reissue Gift Receipt -->
	<TestSequence name="REISSUE_GIFT_RECEIPT">
		<TestStep description="Select Reissue Gift Receipt " action="GIFT_RECEIPT_REISSUE_SELECTION" />
	</TestSequence>
	<!--Select Reprint Document -->
	<TestSequence name="REPRINT_DOCUMENT">
		<TestStep description="Select Reprint Document " action="GENERIC_REPRINT_DOCUMENT" />
	</TestSequence>
	<!--Select Reprint Last Receipt -->
	<TestSequence name="REPRINT_LAST_RECEIPT">
		<TestStep description="Select Reprint Last Receipt " action="REPRINT_LAST_RECEIPT" />
	</TestSequence>
	<!--Select Enter Training Mode -->
	<TestSequence name="TRAINING_MODE">
		<TestStep description="Select enter Training Mode " action="TRAINING_MODE_ENTER" />
		<TestStep action="YES" description="YES (PROMPT_WISH_TO_ENTER_TRAINING_MODE)"/>
	</TestSequence>

