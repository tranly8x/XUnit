	<!-- TEST CASES -->
	<!--Complete a sale transaction-->
	<TestCase name="SALE_COMPLETE_TENDER_BY_CASH" applicationKey="REGISTER" >
		<SequenceRef name="START_SALE_BEFORE_LOGIN" values="!{userid}, !{password}" />
		<SequenceRef name="SELECT_COMM_ASSOC_BY_ID" values="!{associateID}" />
		<SequenceRef name="SKIP_CUST" />        
        <SequenceRef name="SCAN_ITEM" values="!{itemId}" />
		<SequenceRef name="SELECT_AMT_DUE" />
		<SequenceRef name="TENDER_BY_CASH" values="@getTransaction.getTotal.abs"/>
		<SequenceRef name="PRINT_ONLY" />
		<SequenceRef name="CHANGE_DUE" />
    </TestCase>
	<!--Complete a verified transaction-->
	<TestCase name="VERIFIED_RETURN_REFUND_TO_CASH" applicationKey="REGISTER" >
		<Parameter name="saleItem" value="%?ITEMS_DB.ItemId" />
		<SequenceRef name="LOGIN" values="!{userid}, !{password}" />
		<SequenceRef name="START_SALE_LOGGED_IN" />
		<SequenceRef name="SELECT_COMM_ASSOC_BY_ID" values="!{associateID}" />
		<SequenceRef name="CUSTOMER_SEARCH_BY_ID" values="!{custID}"/>
		<SequenceRef name="SKIP_CUSTOMER_NOTIFICATION" />
		<SequenceRef name="SCAN_ITEM" values="!{saleItem}"/>
		<SequenceRef name="CHANGE_PRICE" values="!{saleItem},69.99,%?PRICE_CHANGE_REASONS.ReasonCode,%?PRICE_CHANGE_REASONS.CommentReq"/>
		<SequenceRef name="SELECT_AMT_DUE" />
		<SequenceRef name="TENDER_BY_CASH" values="@getTransaction.getTotal.abs" /> 
		<SequenceRef name="PRINT_ONLY" />
		<Assertion class="dtv.xunit.assertion.LastTransactionAssertion">
			<Parameter name="TYPE_CODE" value="RETAIL_SALE" />
			<Parameter name="STATUS_CODE" value="COMPLETE" />
		</Assertion>		
		<Parameter name="returnComment" value="Test verified return" />
		<SequenceRef name="SELECT_COMM_ASSOC_BY_ID" values="!{associateID}" />
		<SequenceRef name="CUSTOMER_SEARCH_BY_ID" values="!{custID}"/>
		<SequenceRef name="SKIP_CUSTOMER_NOTIFICATION" />
		<SequenceRef name="SEARCH_VERIFIED_RETURN_TRANSACTION" values="@getBarcode(@getLastTransactionId),%?RETURN_REASONS.ReasonCode,%?RETURN_REASONS.CommentReq" />
		<SequenceRef name="SELECT_REFUND" />
		<SequenceRef name="REFUND_TENDER_BY_CASH" values="@getTransaction.getTotal.abs"/>
		<SequenceRef name="PRINT_ONLY" />
    </TestCase>
